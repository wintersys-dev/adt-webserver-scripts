{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Deny",
            "Principal": "*",
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::XXXXBUCKET_NAMEXXXX",
                "arn:aws:s3:::XXXXBUCKET_NAMEXXXX/*"
            ],
            "Condition": {
                "NotIpAddress": {
                    "aws:SourceIp": [
                        "<your-public-ip>/32"
                    ]
                }
            }
        }
    ]
}
