{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Principal": "*",
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::XXXXBUCKET_NAMEXXXX",
                "arn:aws:s3:::XXXXBUCKET_NAMEXXXX/*"
            ],
      "Condition": {
        "StringLike": {
          "aws:Referer": [
            "https://XXXXWEBSITE_URLXXXX"
          ]
        }
        },
        }
    ]
}
